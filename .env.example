# ═══════════════════════════════════
# 晨间星闻 环境变量配置
# ═══════════════════════════════════
# 复制此文件为 .env 并填入真实值

# 服务配置
APP_HOST=0.0.0.0
PORT=8000

# ══ LLM（DeepSeek）══
LLM_API_KEY=sk-your-deepseek-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# 可选：政策英文展示翻译专用通道。留空时复用上面的 LLM 配置。
# 当前按 OpenAI 兼容接口读取；如果使用 DeepL/腾讯/百度/火山等专有接口，需要单独加适配器。
# TRANSLATE_API_KEY=
# TRANSLATE_BASE_URL=https://api.deepseek.com
# TRANSLATE_MODEL=deepseek-chat
# POLICY_DISPLAY_TRANSLATION_LIMIT=15

# ══ 推送配置（可选，发到运小星企微）══
# 如果不配置，只生成日报不推送
PUBLISH_ADMIN_BASE_URL=http://bot.by56.com:8000/admin
PUBLISH_ADMIN_USER=admin
PUBLISH_ADMIN_PASSWORD=your-admin-password
PUBLISH_DEFAULT_USER_ID=18820271886

# ══ 访问认证（可选）══
# 留空 = 不设密码，任何人可访问管理后台
# APP_USERNAME=admin
# APP_PASSWORD=your-password

# ══ CORS（可选）══
CORS_ALLOW_ORIGINS=*
