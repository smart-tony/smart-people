# 你的访问域名，例如 report.example.com
APP_DOMAIN=report.example.com

# 后端服务端口，Docker 部署一般不用改
PORT=8000
APP_HOST=0.0.0.0

# LLM 配置。部署时不要把真实 Key 提交到代码仓库。
LLM_PROVIDER=deepseek
LLM_API_KEY=replace_me
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# 如果前端和 API 同域部署，保持默认即可。
CORS_ALLOW_ORIGINS=*
