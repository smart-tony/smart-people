# ═══════════════════════════════════
# 晨间星闻 环境变量配置
# ═══════════════════════════════════
# 复制此文件为 .env 并填入真实值

# 服务配置
APP_HOST=0.0.0.0
PORT=8000
APP_DATA_DIR=./data

# ══ LLM（DeepSeek）══
LLM_API_KEY=sk-your-deepseek-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# 可选：政策英文展示翻译专用通道。留空时复用上面的 LLM 配置。
# 当前按 OpenAI 兼容接口读取；如果使用 DeepL/腾讯/百度/火山等专有接口，需要单独加适配器。
# TRANSLATE_API_KEY=
# TRANSLATE_BASE_URL=https://api.deepseek.com
# TRANSLATE_MODEL=deepseek-chat
# POLICY_DISPLAY_TRANSLATION_LIMIT=15

# ══ 推送配置（可选，发到运小星企微）══
# 如果不配置，只生成日报不推送
PUBLISH_ADMIN_BASE_URL=http://bot.by56.com:8000/admin
PUBLISH_ADMIN_USER=admin
PUBLISH_ADMIN_PASSWORD=your-admin-password
PUBLISH_DEFAULT_USER_ID=18820271886

# ══ 访问认证（可选）══
# 生产环境必须设置，否则管理后台和抓取接口会开放。
# APP_USERNAME=admin
# APP_PASSWORD=your-password

# ══ CORS（可选）══
# 生产环境建议改为你的正式域名，例如 https://morning.example.com
CORS_ALLOW_ORIGINS=*

# ══ 刷新与兜底策略 ══
LOGISTICS_REFRESH_TOTAL_TIMEOUT=600
LOGISTICS_REFRESH_STALE_SECONDS=900
MIN_LOGISTICS_ITEMS_PER_TASK=10
SQLITE_BUSY_TIMEOUT_MS=5000
LOGISTICS_AUTO_REFRESH_TZ=Asia/Shanghai
LOGISTICS_AUTO_REFRESH_START_HOUR=6
LOGISTICS_AUTO_REFRESH_END_HOUR=18
LOGISTICS_AUTO_REFRESH_INTERVAL_SECONDS=21600
LOGISTICS_HEALTH_MAX_AGE_SECONDS=57600

# ══ 正文质量清洗（可选）══
# 开启后仅对物流/政策正文中仍带导航、客服、公众号、推荐阅读等噪音的内容调用 LLM 清洗。
# 标题不清洗；AI 科技动态和百运百科不清洗。
CLEAN_WITH_LLM=false

# ══ 长正文精炼（可选，默认开启）══
# trafilatura 提取正文后，如果正文过长，则调用 LLM 压缩成更适合晨间星闻展示的精炼内容。
# 失败时保留原文；每轮最多处理 COMPACT_LONG_BODY_MAX_ITEMS 条，避免 token 失控。
COMPACT_LONG_BODY_WITH_LLM=true
COMPACT_LONG_BODY_MIN_CHARS=1800
COMPACT_LONG_BODY_MAX_INPUT_CHARS=5000
COMPACT_LONG_BODY_MAX_ITEMS=8
